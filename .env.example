# Inference script configuration
# Environment server itself does not require LLM keys.

# Required for inference.py if you want live model-generated responses
OPENAI_API_KEY=

# Optional fallback token used by inference.py when OPENAI_API_KEY is absent
HF_TOKEN=

# Optional: OpenAI-compatible endpoint
API_BASE_URL=https://api.openai.com/v1

# Optional: model name for inference.py
MODEL_NAME=gpt-4o-mini

# Optional: environment server URL for HTTP mode
ENV_BASE_URL=http://localhost:7860
